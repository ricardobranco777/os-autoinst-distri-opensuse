From 4dd5d67956daa8ef1d927523fb8721527502a762 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Thu, 28 May 2026 10:07:22 +0200
Subject: [PATCH] tests/integration: fix seccomp tests on big-endian
 architectures

libseccomp 2.4.0 changed seccomp_arch_add() to return -EDOM instead of
-EEXIST when adding an architecture whose endianness differs from the
filter's native architecture. Unlike -EEXIST, -EDOM is not masked by
libseccomp-golang, causing container init to fail with "numerical
argument out of domain" on s390x.

Fix the tests to only add architectures matching the native endianness.

Fixes: https://github.com/opencontainers/runc/issues/4835

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 tests/integration/seccomp.bats | 36 ++++++++++++++++++++++++++--------
 1 file changed, 28 insertions(+), 8 deletions(-)

diff --git a/tests/integration/seccomp.bats b/tests/integration/seccomp.bats
index 160ad16183a..96e352245d9 100644
--- a/tests/integration/seccomp.bats
+++ b/tests/integration/seccomp.bats
@@ -2,6 +2,24 @@
 
 load helpers
 
+# seccomp_archs echoes a JSON array of seccomp architectures matching the
+# native architecture's endianness. Since libseccomp 2.4.0, seccomp_arch_add()
+# returns -EDOM (rather than the previously masked -EEXIST) when adding an
+# architecture whose endianness differs from the filter's, so a single filter
+# can only contain same-endian architectures. See issue #4835.
+function seccomp_archs() {
+	case "$ARCH" in
+	s390x)
+		echo '["SCMP_ARCH_S390","SCMP_ARCH_S390X"]'
+		;;
+	*)
+		# Little-endian: the x86 and ARM families share endianness and so
+		# can coexist in one filter (covers x86_64, aarch64, etc.).
+		echo '["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"]'
+		;;
+	esac
+}
+
 function setup() {
 	setup_busybox
 }
@@ -15,7 +33,8 @@ function teardown() {
 
 	# Compile the test binary and update the config to run it.
 	gcc -static -o rootfs/seccomp_test "${TESTDATA}/${TEST_NAME}.c"
-	update_config ".linux.seccomp = $(<"${TESTDATA}/${TEST_NAME}.json")"
+	update_config ".linux.seccomp = $(<"${TESTDATA}/${TEST_NAME}.json")
+		| .linux.seccomp.architectures = $(seccomp_archs)"
 	update_config '.process.args = ["/seccomp_test"]'
 
 	runc run test_busybox
@@ -27,7 +46,8 @@ function teardown() {
 
 	# Compile the test binary and update the config to run it.
 	gcc -static -o rootfs/seccomp_test2 "${TESTDATA}/${TEST_NAME}.c"
-	update_config ".linux.seccomp = $(<"${TESTDATA}/${TEST_NAME}.json")"
+	update_config ".linux.seccomp = $(<"${TESTDATA}/${TEST_NAME}.json")
+		| .linux.seccomp.architectures = $(seccomp_archs)"
 	update_config '.process.args = ["/seccomp_test2"]'
 
 	runc run test_busybox
@@ -43,7 +63,7 @@ function teardown() {
 			| .process.noNewPrivileges = false
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["mkdir","mkdirat"], "action":"SCMP_ACT_ERRNO"}]
 			}'
 
@@ -57,7 +77,7 @@ function teardown() {
 			| .process.noNewPrivileges = false
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["mkdir","mkdirat"], "action":"SCMP_ACT_ERRNO", "errnoRet": 100}]
 			}'
 
@@ -96,7 +116,7 @@ function flags_value() {
 			| .process.noNewPrivileges = false
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["mkdir", "mkdirat"], "action":"SCMP_ACT_ERRNO"}]
 			}'
 
@@ -161,7 +181,7 @@ function flags_value() {
 			| .process.rlimits = [{"type": "RLIMIT_CORE", "soft": 0, "hard": 0}]
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["mkdir","mkdirat"], "action":"SCMP_ACT_KILL"}]
 			}'
 
@@ -174,7 +194,7 @@ function flags_value() {
 	update_config '   .process.args = ["/bin/true"]
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["mkdir","mkdirat"], "action":"SCMP_ACT_KILL"}]
 			}
 			| .process.rlimits = [{"type": "RLIMIT_CORE", "soft": 0, "hard": 0}]
@@ -196,7 +216,7 @@ function flags_value() {
 			| .process.noNewPrivileges = false
 			| .linux.seccomp = {
 				"defaultAction":"SCMP_ACT_ALLOW",
-				"architectures":["SCMP_ARCH_X86","SCMP_ARCH_X32","SCMP_ARCH_X86_64","SCMP_ARCH_AARCH64","SCMP_ARCH_ARM"],
+				"architectures":'"$(seccomp_archs)"',
 				"syscalls":[{"names":["close_range", "fsopen", "fsconfig", "fspick", "openat2", "open_tree", "move_mount", "mount_setattr"], "action":"SCMP_ACT_ERRNO", "errnoRet": 38}]
 			}'
 
